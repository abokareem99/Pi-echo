{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "eagle-logo.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/payments/approve",
      "dest": "server.js"
    },
    {
      "src": "/api/payments/complete",
      "dest": "server.js"
    },
    {
      "src": "/eagle-logo.png",
      "dest": "/eagle-logo.png"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
